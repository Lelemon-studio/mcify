  },
  "author": "Lelemon Studio <contacto@lelemon.cl>",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "astro build",
    "dev": "astro dev --port 5174",
    "preview": "astro preview --port 5174",
    "test": "vitest run --passWithNoTests",
    "lint": "echo \"(lint runs at root)\"",
