{
  "name": "@mcify/inspector",
  "version": "0.1.0-alpha.1",
  "description": "Local web inspector for `mcify dev` — tools, calls log, playground.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Lelemon-studio/mcify/tree/main/packages/inspector#readme",
  "bugs": "https://github.com/Lelemon-studio/mcify/issues",
  "repository": {
    "type": "git",
