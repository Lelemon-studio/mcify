{
  "name": "@mcify/runtime",
  "version": "0.1.0-alpha.1",
  "description": "MCP server runtime for mcify — Hono-based, multi-target (Node, Bun, Workers).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.js"
    },
    "./bun": {
      "types": "./dist/adapters/bun.d.ts",
      "import": "./dist/adapters/bun.js"
    },
    "./workers": {
      "types": "./dist/adapters/workers.d.ts",
      "import": "./dist/adapters/workers.js"
    },
    "./inspector": {
      "types": "./dist/inspector.d.ts",
      "import": "./dist/inspector.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Lelemon-studio/mcify/tree/main/packages/runtime#readme",
  "bugs": "https://github.com/Lelemon-studio/mcify/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lelemon-studio/mcify.git",
    "directory": "packages/runtime"
  },
  "author": "Lelemon Studio <contacto@lelemon.cl>",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"(lint not configured yet)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@mcify/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "hono": "^4.6.14",
    "pino": "^9.5.0"
  },
  "peerDependencies": {
    "@hono/node-server": "^1.13.0",
    "ws": "^8.18.0"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.0",
    "@types/ws": "^8.5.13",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  }
}
