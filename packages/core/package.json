{
  "name": "@mcify/core",
  "version": "0.1.0-alpha.1",
  "description": "Builder library for mcify MCP servers — schema, server, auth helpers, logger.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Lelemon-studio/mcify/tree/main/packages/core#readme",
  "bugs": "https://github.com/Lelemon-studio/mcify/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lelemon-studio/mcify.git",
    "directory": "packages/core"
  },
  "author": "Lelemon Studio <contacto@lelemon.cl>",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"(lint not configured yet)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  }
}
