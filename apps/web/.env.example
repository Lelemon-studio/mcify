# Public — embedded in the static bundle. Vite/Astro require the PUBLIC_ prefix.
PUBLIC_TURNSTILE_SITEKEY=0x4AAAAAADJrc6_XNgSnUBl1
PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# Server-side — never embedded. Used by future form-handling functions
# that need to verify Turnstile challenges. Set as a Pages env var (encrypted).
TURNSTILE_SECRET_KEY=
