---
import { Code } from 'astro:components';

const initSnippet = `npx @mcify/cli@alpha init my-mcp
cd my-mcp
pnpm install`;

const devSnippet = `pnpm dev
# → http://localhost:8888/mcp   (your server)
# → http://localhost:3001       (inspector)`;

const deploySnippet = `mcify deploy cloudflare        # Cloudflare Workers
mcify deploy vercel --prod     # Vercel Edge
mcify deploy fly               # Fly.io
mcify deploy railway           # Railway
mcify deploy docker --push     # Docker → registry`;
---

<section id="quick-start" class="section border-t border-ink-800/80">
  <div class="container-wide">
    <div class="mb-12">
      <h2 class="section-title">Three steps</h2>
      <p class="section-lead">From zero to a deployable MCP server. AGENTS.md ships with the template, so any AI assistant follows the conventions automatically.</p>
    </div>

    <ol class="grid gap-4 lg:grid-cols-3">
      <li class="card relative">
        <span class="absolute -top-3 left-5 inline-flex items-center justify-center rounded-md bg-accent px-2 py-0.5 text-xs font-semibold text-ink-950">01</span>
        <h3 class="mb-3 mt-2 text-base font-semibold tracking-tight">Scaffold</h3>
        <pre class="overflow-x-auto rounded-md bg-ink-950 p-3 text-[12px] leading-relaxed text-ink-200"><Code code={initSnippet} lang="bash" theme="github-dark-default" /></pre>
        <p class="mt-3 text-sm text-ink-400">
          Generates the project, an <code class="text-ink-200">AGENTS.md</code> for your AI agent, and a <code class="text-ink-200">mcify.config.ts</code> with one example tool.
        </p>
      </li>

      <li class="card relative">
        <span class="absolute -top-3 left-5 inline-flex items-center justify-center rounded-md bg-accent px-2 py-0.5 text-xs font-semibold text-ink-950">02</span>
        <h3 class="mb-3 mt-2 text-base font-semibold tracking-tight">Develop with the inspector</h3>
        <pre class="overflow-x-auto rounded-md bg-ink-950 p-3 text-[12px] leading-relaxed text-ink-200"><Code code={devSnippet} lang="bash" theme="github-dark-default" /></pre>
        <p class="mt-3 text-sm text-ink-400">
          Hot reload reflects your tool edits in the inspector instantly. Invoke from the Playground tab; see latency, args, and result live.
        </p>
      </li>

      <li class="card relative">
        <span class="absolute -top-3 left-5 inline-flex items-center justify-center rounded-md bg-accent px-2 py-0.5 text-xs font-semibold text-ink-950">03</span>
        <h3 class="mb-3 mt-2 text-base font-semibold tracking-tight">Ship</h3>
        <pre class="overflow-x-auto rounded-md bg-ink-950 p-3 text-[12px] leading-relaxed text-ink-200"><Code code={deploySnippet} lang="bash" theme="github-dark-default" /></pre>
        <p class="mt-3 text-sm text-ink-400">
          One command per target. Bundles, generates the right config (wrangler.toml, fly.toml, railway.json…), invokes the platform's CLI for you.
        </p>
      </li>
    </ol>
  </div>
</section>
