---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-800/80 py-10">
  <div class="container-wide flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
    <div class="flex items-center gap-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 32 32"
        class="h-6 w-6 text-accent"
        aria-hidden="true"
      >
        <g
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M9 8 Q6 8 6 11 L6 14 Q6 16 4 16 Q6 16 6 18 L6 21 Q6 24 9 24" />
          <path
            d="M12 24 L12 16 Q12 13 14.5 13 Q17 13 17 16 L17 24 M17 16 Q17 13 19.5 13 Q22 13 22 16 L22 24"
          />
          <path d="M23 8 Q26 8 26 11 L26 14 Q26 16 28 16 Q26 16 26 18 L26 21 Q26 24 23 24" />
        </g>
      </svg>
      <div class="text-sm">
        <div class="font-semibold tracking-tight">mcify</div>
        <div class="text-ink-500">
          Apache 2.0 · maintained by
          <a class="hover:text-ink-300" href="https://lelemon.cl" rel="noreferrer noopener" target="_blank">Lelemon Studio</a>
        </div>
      </div>
    </div>

    <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-400">
      <a class="hover:text-ink-100" href="https://docs.mcify.dev">Docs</a>
      <a class="hover:text-ink-100" href="https://github.com/Lelemon-studio/mcify" rel="noreferrer noopener" target="_blank">GitHub</a>
      <a class="hover:text-ink-100" href="https://www.npmjs.com/package/@mcify/cli" rel="noreferrer noopener" target="_blank">npm</a>
      <a class="hover:text-ink-100" href="https://docs.mcify.dev/llms-full.txt">llms.txt</a>
      <a class="hover:text-ink-100" href="https://github.com/Lelemon-studio/mcify/issues" rel="noreferrer noopener" target="_blank">Issues</a>
    </nav>
  </div>

  <div class="container-wide mt-6 text-xs text-ink-600">© {year} Lelemon Studio. mcify is open source software.</div>
</footer>
