---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="404 — mcify" description="Page not found">
  <Nav />
  <main class="container-narrow flex flex-1 flex-col items-center justify-center py-32 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-500">error 404</p>
    <h1 class="mt-3 text-5xl font-semibold tracking-tight3 md:text-7xl">Not found</h1>
    <p class="mt-4 max-w-md text-ink-400">
      The page you're after doesn't exist (or moved). Try the homepage, the GitHub repo, or
      the canonical install snippet:
    </p>
    <div class="mt-6 rounded-lg border border-ink-800 bg-ink-900/70 px-4 py-3 font-mono text-sm">
      <span class="text-ink-500">$</span> npx @mcify/cli@alpha init my-mcp
    </div>
    <div class="mt-8 flex flex-col gap-3 md:flex-row">
      <a class="btn-primary" href="/">Home</a>
      <a class="btn-secondary" href="https://github.com/Lelemon-studio/mcify" rel="noreferrer noopener" target="_blank">
        GitHub
      </a>
    </div>
  </main>
</Layout>
