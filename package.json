{
  "name": "mcify",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open source MCP platform — CLI, runtime, inspector. Convierte tu API en MCP en minutos.",
  "license": "Apache-2.0",
  "homepage": "https://mcify.dev",
  "bugs": "https://github.com/Lelemon-studio/mcify/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lelemon-studio/mcify.git"
  },
  "author": "Lelemon Studio <contacto@lelemon.cl>",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.0"
  }
}
